# OSS Health Checker — Backend Environment Variables
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and must NEVER be committed.

# --- GitHub API ---
# Personal Access Token (classic) for GitHub REST API.
# Without a token: 60 requests/hour. With a token: 5,000 requests/hour.
# Generate at: https://github.com/settings/tokens
# Required scopes: `repo` (read public repo data), `read:org` (org metadata)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# --- Gemini API ---
# Google Gemini API key for AI-based improvement suggestions.
# Generate at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Local dev example: http://localhost:3000
# Production: replace with the deployed frontend URL.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Application ---
# Enable verbose logging and FastAPI debug mode. Default: false.
DEBUG=false
